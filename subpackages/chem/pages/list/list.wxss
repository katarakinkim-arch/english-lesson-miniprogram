/* pages/index/index.wxss — 学科选择首页 */
.page-wrap { padding: 0 24rpx 60rpx; }

.hero-banner {
  margin: 24rpx 0 32rpx;
  padding: 44rpx 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(160deg, #0d1b2a 0%, #1a365d 55%, #2c5282 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(26, 54, 93, 0.25);
}
.hb-title { font-size: 44rpx; font-weight: 800; letter-spacing: 2rpx; }
.hb-sub { font-size: 24rpx; color: rgba(255, 255, 255, 0.72); margin-top: 14rpx; }

.subj-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.subj-card {
  width: calc((100% - 40rpx) / 3);
  box-sizing: border-box;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(26, 54, 93, 0.06);
  border: 2rpx solid #eef1f6;
}
.subj-card:active { transform: scale(0.97); }
.subj-emoji {
  font-size: 50rpx;
  width: 92rpx; height: 92rpx; line-height: 92rpx;
  border-radius: 24rpx;
  margin: 0 auto 12rpx;
}
.subj-name { font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.subj-count { font-size: 22rpx; color: #8a90a0; margin-top: 6rpx; }

.tip { text-align: center; font-size: 22rpx; color: #9aa0ab; margin-top: 32rpx; line-height: 1.6; }
