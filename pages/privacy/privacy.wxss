.page { padding: 24rpx; background: #f5f6fa; min-height: 100vh; }
.hero { background: #1a365d; border-radius: 20rpx; padding: 36rpx 32rpx; margin-bottom: 24rpx; }
.hero-t { color: #fff; font-size: 36rpx; font-weight: 700; }
.hero-s { color: #aebfd9; font-size: 22rpx; margin-top: 8rpx; }

.block { background: #fff; border-radius: 20rpx; padding: 28rpx 28rpx 12rpx; margin-bottom: 22rpx; }
.h { font-size: 30rpx; font-weight: 700; color: #1a365d; margin-bottom: 16rpx; }
.p { font-size: 26rpx; color: #4a4a5a; line-height: 1.8; margin-bottom: 16rpx; }
.tip { font-size: 22rpx; color: #98a2b3; text-align: center; padding: 8rpx 20rpx; line-height: 1.7; }
