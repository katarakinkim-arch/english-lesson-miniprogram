/* pages/downloads/downloads.wxss */
.page-wrap { padding: 0 0 40rpx; }

.pg-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 24rpx 4rpx;
}
.pg-title { font-size: 36rpx; font-weight: 800; color: #1a1a2e; }
.pg-count {
  font-size: 22rpx; font-weight: 600; color: #fff; background: #1a365d;
  border-radius: 20rpx; padding: 2rpx 14rpx; margin-left: 12rpx; vertical-align: middle;
}
.pg-clear { font-size: 26rpx; color: #c0392b; padding: 8rpx 20rpx; }
.pg-clear:active { opacity: .6; }

.doc-card-time { font-size: 22rpx; color: #aaa; margin-top: 8rpx; }
