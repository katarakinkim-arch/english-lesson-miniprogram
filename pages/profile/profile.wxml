<view class="page">
  <!-- 用户信息卡 -->
  <view class="profile-card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatarUrl || '/images/tabbar/person.png'}}" mode="aspectFill"></image>
    </button>
    <view class="info">
      <input class="nick" type="nickname" placeholder="点击设置昵称" placeholder-class="nick-ph" value="{{nickName}}" bindblur="onNickname" bindconfirm="onNickname" />
      <view class="uid">ID: {{openid || '----'}}</view>
    </view>
  </view>

  <view wx:if="{{isLocal}}" class="tip">游客模式：数据仅保存在本机。配置云开发后可在多设备同步。</view>

  <!-- 统计 -->
  <view class="stats">
    <view class="stat"><view class="n">{{stats.favorites}}</view><view class="l">收藏</view></view>
    <view class="stat"><view class="n">{{stats.downloads}}</view><view class="l">下载</view></view>
    <view class="stat"><view class="n">{{stats.recents}}</view><view class="l">最近</view></view>
  </view>

  <!-- 下载记录 -->
  <view class="block">
    <view class="block-h">
      <text>📥 下载记录</text>
      <text wx:if="{{downloads.length}}" class="clear" bindtap="clearDownloads">清空</text>
    </view>
    <view wx:if="{{!downloads.length}}" class="empty">暂无下载记录</view>
    <view wx:for="{{downloads}}" wx:key="id" class="doc-card card-hover" data-id="{{item.id}}" bindtap="openDetail">
      <view class="doc-card-icon">📄</view>
      <view class="doc-card-body">
        <view class="doc-card-title">{{item.title}}</view>
        <view class="doc-card-sub">{{item.sub}}</view>
      </view>
      <view class="doc-card-arrow">›</view>
    </view>
  </view>

  <!-- 浏览历史 -->
  <view class="block">
    <view class="block-h">
      <text>🕘 浏览历史</text>
      <text wx:if="{{recents.length}}" class="clear" bindtap="clearRecents">清空</text>
    </view>
    <view wx:if="{{!recents.length}}" class="empty">暂无浏览记录</view>
    <view wx:for="{{recents}}" wx:key="id" class="doc-card card-hover" data-id="{{item.id}}" bindtap="openDetail">
      <view class="doc-card-icon">📄</view>
      <view class="doc-card-body">
        <view class="doc-card-title">{{item.title}}</view>
        <view class="doc-card-sub">{{item.sub}}</view>
      </view>
      <view class="doc-card-arrow">›</view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="block">
    <view class="block-h"><text>⚙️ 数据管理</text></view>
    <view class="op-row" bindtap="clearAll">
      <text>清空全部云端数据</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view style="height:40rpx"></view>
</view>
