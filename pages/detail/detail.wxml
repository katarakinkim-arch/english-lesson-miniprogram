<view class="page-wrap" wx:if="{{!loading && plan}}">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-formats">
      <text class="hero-badge">Word</text>
      <text class="hero-badge">PDF</text>
      <text class="hero-badge">PPT</text>
    </view>
    <view class="hero-title">{{plan.title}}</view>
    <view class="hero-sub">{{plan.grade}} · {{plan.subject}} · {{plan.textbook}} · 第{{plan.unitNumber}}单元 · {{plan.lessonTypeName}}</view>
    <view class="hero-stats">
      <view class="hero-stat"><view class="n">{{pages}}</view><view class="l">页数</view></view>
      <view class="hero-stat"><view class="n">{{plan.duration}}</view><view class="l">分钟</view></view>
      <view class="hero-stat"><view class="n">{{plan.viewCount}}</view><view class="l">浏览</view></view>
      <view class="hero-stat"><view class="n">{{plan.downloadCount}}</view><view class="l">下载</view></view>
    </view>
  </view>

  <!-- 文档介绍 -->
  <view class="card intro">
    <view class="intro-h">📋 文档介绍</view>
    <view class="intro-list">
      <view class="intro-item" wx:for="{{desc}}" wx:key="*this">
        <text class="check">✓</text><text class="intro-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 内容分区 -->
  <view class="card section" wx:for="{{sections}}" wx:key="key">
    <view class="section-h">{{item.title}}</view>

    <view wx:if="{{item.type==='text'}}" class="section-body">{{item.body}}</view>

    <view wx:if="{{item.type==='list'}}" class="list-box">
      <view class="list-item" wx:for="{{item.items}}" wx:for-item="it" wx:key="*this">{{it}}</view>
    </view>

    <view wx:if="{{item.type==='steps'}}" class="steps">
      <view class="step" wx:for="{{item.steps}}" wx:for-item="st" wx:key="step">
        <view class="step-h">{{st.step}}<text class="step-time">{{st.time}}分钟</text></view>
        <view class="step-body">{{st.content}}</view>
      </view>
    </view>

    <view wx:if="{{item.type==='pre'}}" class="pre-box">{{item.body}}</view>
  </view>

  <view style="height:200rpx"></view>
</view>

<!-- 底部下载栏 -->
<view class="dl-bar" wx:if="{{!loading && plan}}">
  <view class="dl-fav {{favorited?'on':''}}" bindtap="toggleFavorite">{{favorited ? '★' : '☆'}}</view>
  <view class="dl-bar-row">
    <view class="dl-fmts">
      <view class="dl-fmt {{fmt==='word'?'active':''}}" data-f="word" bindtap="selectFmt">📝 Word</view>
      <view class="dl-fmt {{fmt==='pdf'?'active':''}}" data-f="pdf" bindtap="selectFmt">📄 PDF</view>
      <view class="dl-fmt {{fmt==='ppt'?'active':''}}" data-f="ppt" bindtap="selectFmt">📊 PPT</view>
    </view>
    <view class="dl-btn {{generating?'loading':''}}" bindtap="onDownload">
      {{generating ? '生成中...' : '📥 下载' + (fmt==='word'?' Word':fmt==='pdf'?' PDF':' PPT')}}
    </view>
  </view>
</view>

<!-- 隐藏画布：用于端上生成 PDF（绘制中文后嵌入） -->
<canvas type="2d" id="pdfCanvas" style="position:fixed;left:-9999px;top:0;width:595px;height:842px;"></canvas>
