/* pages/detail/detail.wxss */
.page-wrap { padding: 0 24rpx; }

/* Hero */
.hero {
  margin: 24rpx 0;
  padding: 36rpx 32rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(160deg, #0d1b2a 0%, #1a365d 50%, #2c5282 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(26, 54, 93, 0.25);
}
.hero-formats { display: flex; gap: 12rpx; margin-bottom: 18rpx; }
.hero-badge {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.15); color: #fff; font-weight: 500;
}
.hero-title { font-size: 38rpx; font-weight: 800; line-height: 1.35; letter-spacing: 1rpx; }
.hero-sub { font-size: 24rpx; color: rgba(255, 255, 255, 0.7); margin-top: 14rpx; }
.hero-stats {
  display: flex; margin-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15); padding-top: 22rpx;
}
.hero-stat { flex: 1; text-align: center; }
.hero-stat .n { font-size: 34rpx; font-weight: 700; }
.hero-stat .l { font-size: 21rpx; color: rgba(255, 255, 255, 0.6); margin-top: 4rpx; }

/* Card */
.card {
  background: #fff; border-radius: 20rpx; padding: 28rpx 26rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(26, 54, 93, 0.06);
}

/* Intro */
.intro-h { font-size: 30rpx; font-weight: 700; color: #1a365d; margin-bottom: 16rpx; }
.intro-list { display: flex; flex-direction: column; gap: 12rpx; }
.intro-item { display: flex; align-items: flex-start; gap: 12rpx; font-size: 25rpx; color: #4a4a5a; }
.intro-item .check { color: #2d5016; font-weight: 700; }
.intro-text { flex: 1; }

/* Section */
.section-h {
  font-size: 30rpx; font-weight: 700; color: #1a365d;
  padding-left: 18rpx; border-left: 8rpx solid #1a365d; margin-bottom: 18rpx; line-height: 1.3;
}
.section-body {
  font-size: 26rpx; color: #4a4a5a; line-height: 1.8;
  white-space: pre-wrap; word-break: break-word;
}
.list-box { display: flex; flex-direction: column; gap: 14rpx; }
.list-item {
  font-size: 26rpx; color: #4a4a5a; line-height: 1.8; padding-left: 24rpx;
  position: relative; white-space: pre-wrap;
}
.list-item::before {
  content: ''; position: absolute; left: 4rpx; top: 18rpx;
  width: 10rpx; height: 10rpx; border-radius: 50%; background: #2c5282;
}

/* Steps */
.steps { display: flex; flex-direction: column; gap: 22rpx; }
.step { border-left: 4rpx solid #e8f0fe; padding-left: 22rpx; }
.step-h { font-size: 27rpx; font-weight: 700; color: #1a365d; margin-bottom: 10rpx; }
.step-time {
  font-size: 22rpx; color: #fff; background: #2c5282; border-radius: 8rpx;
  padding: 2rpx 12rpx; margin-left: 12rpx; font-weight: 400;
}
.step-body {
  font-size: 25rpx; color: #4a4a5a; line-height: 1.8;
  white-space: pre-wrap; word-break: break-word;
}

/* Pre (blackboard) */
.pre-box {
  font-size: 23rpx; color: #2d5016; background: #f0f7eb; border-radius: 12rpx;
  padding: 20rpx; white-space: pre-wrap; font-family: "Courier New", monospace;
  line-height: 1.5; overflow-x: auto;
}

/* Download bar */
.dl-bar {
  position: fixed; left: 0; right: 0; bottom: 0; background: #fff;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06); z-index: 50;
}
.dl-fmts { display: flex; gap: 14rpx; margin-bottom: 16rpx; }
.dl-fmt {
  flex: 1; text-align: center; padding: 14rpx 0; font-size: 25rpx;
  color: #4a4a5a; background: #f0f1f5; border-radius: 14rpx; border: 2rpx solid transparent;
}
.dl-fmt.active { color: #1a365d; background: #e8f0fe; border-color: #1a365d; font-weight: 600; }
.dl-btn {
  background: #1a365d; color: #fff; text-align: center; font-size: 30rpx; font-weight: 600;
  padding: 24rpx 0; border-radius: 16rpx; letter-spacing: 2rpx;
}
.dl-btn.loading { opacity: .7; }
.dl-btn:active { background: #142844; }
