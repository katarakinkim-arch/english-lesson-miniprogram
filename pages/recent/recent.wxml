<view class="page-wrap">
  <view class="pg-head" wx:if="{{list.length > 0}}">
    <view class="pg-title">最近浏览<text class="pg-count">{{list.length}}</text></view>
    <view class="pg-clear" bindtap="clearAll">清空</view>
  </view>

  <view class="list" wx:if="{{list.length > 0}}">
    <view class="doc-card" wx:for="{{list}}" wx:key="id"
          data-id="{{item.id}}" bindtap="openDetail" hover-class="card-hover">
      <view class="doc-card-icon">📄</view>
      <view class="doc-card-body">
        <view class="doc-card-title">{{item.title}}</view>
        <view class="doc-card-sub">{{item.sub}}</view>
        <view class="doc-card-desc">{{item.desc}}</view>
      </view>
      <view class="doc-card-arrow">›</view>
    </view>
  </view>

  <view wx:else class="empty">
    <view class="empty-ico">🕒</view>
    <view class="empty-text">还没有浏览记录</view>
    <view class="empty-tip">打开任意教案后会记录在这里</view>
  </view>
</view>
