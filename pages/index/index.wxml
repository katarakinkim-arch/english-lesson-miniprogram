<view class="page-wrap">
  <view class="hero-banner">
    <view class="hb-title">高中教案库</view>
    <view class="hb-sub">人教版 2019 · 全 9 科 · {{total}} 课 · 无脑可用</view>
  </view>

  <view class="subj-grid">
    <view class="subj-card" wx:for="{{subjects}}" wx:key="key"
          data-root="{{item.root}}" bindtap="openSubject" hover-class="card-hover">
      <view class="subj-emoji" style="background:{{item.color}}15;color:{{item.color}}">{{item.emoji}}</view>
      <view class="subj-name">{{item.name}}</view>
      <view class="subj-count">{{item.count}} 课</view>
    </view>
  </view>

  <view class="tip">点选学科进入教案列表 · 支持搜索 / 按册筛选 / 一键下载 Word·PDF·PPT</view>
</view>
