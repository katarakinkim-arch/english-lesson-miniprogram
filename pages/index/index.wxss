/* pages/index/index.wxss — 教案库列表页（TDesign 视觉风格，零依赖） */
.page-wrap { padding: 0; }

/* 搜索框 */
.top-bar {
  padding: 16rpx 24rpx 8rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}
.search-box {
  display: flex;
  align-items: center;
  background: #f0f1f5;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 72rpx;
}
.search-ico { font-size: 28rpx; margin-right: 12rpx; opacity: .5; }
.search-input { flex: 1; font-size: 27rpx; color: #1a1a2e; }
.search-clear {
  font-size: 28rpx; color: #aaa;
  width: 40rpx; text-align: center;
}

/* 搜索历史面板 */
.hist-panel {
  position: absolute; left: 24rpx; right: 24rpx; top: 96rpx;
  background: #fff; border-radius: 16rpx; padding: 20rpx 22rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12); z-index: 20;
}
.hist-h {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 24rpx; color: #9aa0ab; margin-bottom: 16rpx;
}
.hist-clear { color: #c0392b; font-size: 23rpx; }
.hist-tags { display: flex; flex-wrap: wrap; gap: 14rpx; }
.hist-tag {
  font-size: 25rpx; color: #4a4a5a; background: #f0f1f5;
  padding: 12rpx 24rpx; border-radius: 999rpx;
}
.hist-tag:active { background: #e8f0fe; }

/* 筛选 */
.filter-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx 4rpx;
  background: #fff;
}
.filter-chip {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #4a4a5a;
  background: #f0f1f5;
  border-radius: 999rpx;
  transition: all .2s;
}
.filter-chip.active {
  color: #fff;
  background: #1a365d;
  font-weight: 600;
}

.type-scroll { white-space: nowrap; padding: 12rpx 24rpx 16rpx; background: #fff; }
.type-row { display: inline-flex; gap: 16rpx; }
.type-chip {
  display: inline-block;
  padding: 10rpx 26rpx;
  font-size: 24rpx;
  color: #4a4a5a;
  background: #f0f1f5;
  border-radius: 999rpx;
}
.type-chip.active { color: #2c5282; background: #e8f0fe; font-weight: 600; }

/* 列表 */
.list { padding: 8rpx 24rpx 40rpx; }

.doc-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(26, 54, 93, 0.06);
}
.card-hover { background: #f7f9fc; }

.doc-card-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 16rpx;
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.doc-card-body { flex: 1; min-width: 0; }
.doc-card-title { font-size: 29rpx; font-weight: 600; color: #1a1a2e; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.doc-card-sub { font-size: 23rpx; color: #8a90a0; margin-top: 6rpx; line-height: 1.3; }
.doc-card-arrow { margin-left: 12rpx; font-size: 40rpx; color: #d0d4dc; flex-shrink: 0; align-self: center; }

/* 空状态 */
.empty { text-align: center; padding: 120rpx 40rpx; }
.empty-ico { font-size: 90rpx; }
.empty-text { font-size: 28rpx; color: #4a4a5a; margin-top: 20rpx; }
.empty-tip { font-size: 23rpx; color: #aaa; margin-top: 10rpx; }

/* 骨架 */
.doc-card.skel { height: 110rpx; background: #f2f3f7; animation: pulse 1.2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:.6} 50%{opacity:1} }
